class Solution {
    public String mergeAlternately(String word1, String word2) {

        StringBuilder sb = new StringBuilder();

        for (int i = 0; i < Math.max(word1.length(), word2.length()); i++) { // Math.max() longer string ki length return karta hai.
            if (i < word1.length()) sb.append(word1.charAt(i)); //agar i word1 ke andar hai to us character ko add karenge
            if (i < word2.length()) sb.append(word2.charAt(i)); //same word2
        }

        return sb.toString();
    }
}
